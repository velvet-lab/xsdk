{
  "dotnet.unitTests.runSettingsPath": "./xsdk.runsettings",
  "sonarlint.connectedMode.project": {
    "connectionId": "velvet-lab",
    "projectKey": "velvet-lab_xsdk"
  },
  "githubPullRequests.allowFetch": true,
  "githubPullRequests.notifications": "pullRequests",
  "githubPullRequests.pullBranch": "always",
  "githubPullRequests.pushBranch": "always",
  "github.copilot.chat.codesearch.agent.enabled": true,
  "github.copilot.chat.commitMessageGeneration.instructions": [
    {
      "file": ".github/guidance/commit-message-instructions.md"
    }
  ],
  "github.copilot.chat.reviewSelection.instructions": [
    {
      "file": ".github/guidance/review-instructions.md"
    }
  ],
  "github.copilot.chat.pullRequestDescriptionGeneration.instructions": [
    {
      "file": ".github/guidance/pull-request-description-instructions.md"
    }
  ],

}
